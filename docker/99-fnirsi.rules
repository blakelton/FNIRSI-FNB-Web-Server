# udev rules for FNIRSI FNB58 USB Power Meter
# Place this file in /etc/udev/rules.d/ on the host system

# The app (app.py / device/usb_reader.py) uses hidapi, which accesses the meter
# through /dev/hidraw*, so hidraw access is what actually matters. The usb rules
# below are kept for the standalone pyusb scripts (fnb48p_monitor.py, etc.).

# --- hidraw access for hidapi (PRIMARY) ---
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="2e3c", ATTRS{idProduct}=="0049", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="2e3c", ATTRS{idProduct}=="5558", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="003a", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="003b", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0716", ATTRS{idProduct}=="5030", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0716", ATTRS{idProduct}=="5031", MODE="0666", GROUP="plugdev"

# --- raw USB access for the standalone pyusb scripts ---
SUBSYSTEM=="usb", ATTR{idVendor}=="2e3c", ATTR{idProduct}=="0049", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTR{idVendor}=="2e3c", ATTR{idProduct}=="5558", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="003a", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", ATTR{idProduct}=="003b", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTR{idVendor}=="0716", ATTR{idProduct}=="5030", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTR{idVendor}=="0716", ATTR{idProduct}=="5031", MODE="0666", GROUP="plugdev"

# Alternative: Allow specific user (replace 'username' with your username)
# SUBSYSTEM=="usb", ATTR{idVendor}=="0716", MODE="0666", OWNER="username"

# After creating this file, reload udev rules:
# sudo udevadm control --reload-rules
# sudo udevadm trigger

# Then reconnect the device or run:
# sudo udevadm trigger --action=change
